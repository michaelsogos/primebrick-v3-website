---
/**
 * Cloud provider logos.
 * Uses thesvg (MIT licensed package) for accurate brand SVG paths.
 * AWS: MIT license (SVG representation)
 * Azure: brand-use license (subject to Microsoft brand guidelines)
 * Google Cloud, Alibaba Cloud, Docker, Kubernetes: from simple-icons (CC0)
 *
 * Usage is nominative fair use: indicating deployment compatibility,
 * not claiming endorsement or partnership.
 *
 * IMPORTANT: Do not modify the SVG paths or brand colors.
 */
import { siAlibabacloud, siDocker, siKubernetes } from 'simple-icons';
import awsIcon from 'thesvg/aws';
import azureIcon from 'thesvg/azure';

// Handle both default and named exports
const aws = (awsIcon as any).default ?? awsIcon;
const azure = (azureIcon as any).default ?? azureIcon;

// Extract path data from thesvg icons (they may have multiple paths)
function extractPaths(svg: string): string[] {
  const matches = svg.match(/d="([^"]+)"/g);
  if (!matches) return [];
  return matches.map((m) => m.replace(/d="/, '').replace(/"$/, ''));
}

const awsPaths = extractPaths(aws.svg);
const azurePaths = extractPaths(azure.svg);

const svgIcons = [
  {
    name: 'AWS',
    paths: awsPaths,
    color: `#${aws.hex}`,
    viewBox: '0 0 24 24',
  },
  {
    name: 'Azure',
    paths: azurePaths,
    color: `#${azure.hex}`,
    viewBox: '0 0 256 199',
  },
  {
    name: 'Google Cloud',
    multicolor: [
      { d: 'M14.5 3.5c1.35-.31 2.68-.18 3.86.46 1.18.64 2.11 1.69 2.66 2.97.55 1.28.69 2.72.4 4.1-.29 1.38-.99 2.62-2 3.54l.36-1.62c.16-.72.13-1.47-.09-2.17-.22-.7-.62-1.32-1.16-1.79-.54-.47-1.19-.76-1.88-.84-.69-.08-1.39.05-2.01.38l-1.42.71-.71-1.42c-.32-.62-.45-1.32-.37-2.01.08-.69.37-1.34.84-1.88.47-.54 1.09-.94 1.79-1.16.7-.22 1.45-.25 2.17-.09z', fill: '#4285F4' },
      { d: 'M19.36 4.96c-.55-1.28-1.48-2.33-2.66-2.97-1.18-.64-2.51-.77-3.86-.46-1.35.31-2.56 1.02-3.46 2.02l-1.42 1.42 1.42.71c.62.32 1.32.45 2.01.37.69-.08 1.34-.37 1.88-.84.54-.47 1.09-.77 1.79-.99.7-.22 1.45-.25 2.17-.09l1.62-.36z', fill: '#EA4335' },
      { d: 'M12 21.5c-2.07 0-4.06-.76-5.59-2.13-1.53-1.37-2.43-3.25-2.51-5.25-.08-2 .66-3.95 2.07-5.43l1.42-1.42-1.42-.71c-.62-.32-1.32-.45-2.01-.37-.69.08-1.34.37-1.88.84-.54.47-.94 1.09-1.16 1.79-.22.7-.25 1.45-.09 2.17l.36 1.62c-1.01-.92-1.71-2.16-2-3.54-.29-1.38-.15-2.82.4-4.1.55-1.28 1.48-2.33 2.66-2.97 1.18-.64 2.51-.77 3.86-.46l-1.62.36c-.72.16-1.47.13-2.17-.09-.7-.22-1.32-.62-1.79-1.16-.47-.54-.76-1.19-.84-1.88-.08-.69.05-1.39.38-2.01l.71-1.42L5.95 4.6c-1.41 1.48-2.15 3.43-2.07 5.43.08 2 .98 3.88 2.51 5.25C7.94 20.74 9.93 21.5 12 21.5z', fill: '#FBBC04' },
      { d: 'M12 21.5c2.07 0 4.06-.76 5.59-2.13 1.53-1.37 2.43-3.25 2.51-5.25.08-2-.66-3.95-2.07-5.43l-1.42-1.42 1.42-.71c.62-.32 1.32-.45 2.01-.37.69.08 1.34.37 1.88.84.54.47.94 1.09 1.16 1.79.22.7.25 1.45.09 2.17l-.36 1.62c1.01-.92 1.71-2.16 2-3.54.29-1.38.15-2.82-.4-4.1l.36 1.62c.16.72.13 1.47-.09 2.17-.22.7-.62 1.32-1.16 1.79l-1.42 1.42 1.42.71c.62.32 1.32.45 2.01.37.69-.08 1.34-.37 1.88-.84l-1.42 1.42c-1.41 1.48-3.4 2.24-5.47 2.24z', fill: '#34A853' },
    ],
    viewBox: '0 0 24 24',
  },
  {
    name: 'Alibaba Cloud',
    paths: [siAlibabacloud.path],
    color: `#${siAlibabacloud.hex}`,
    viewBox: '0 0 24 24',
  },
  {
    name: 'Docker',
    paths: [siDocker.path],
    color: `#${siDocker.hex}`,
    viewBox: '0 0 24 24',
  },
  {
    name: 'Kubernetes',
    paths: [siKubernetes.path],
    color: `#${siKubernetes.hex}`,
    viewBox: '0 0 24 24',
  },
];
---

<div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
  {svgIcons.map((p) => (
    <div
      class="group flex flex-col items-center gap-2 transition-all duration-300 hover:scale-110"
      title={p.name}
    >
      <svg
        class="h-10 w-10 transition-all duration-300 group-hover:scale-110"
        viewBox={p.viewBox}
        fill="currentColor"
        style={p.color ? `color: ${p.color};` : ''}
        role="img"
        aria-label={p.name}
      >
        {p.multicolor
          ? p.multicolor.map((path: { d: string; fill: string }) => (
              <path d={path.d} fill={path.fill} />
            ))
          : p.paths.map((path: string) => <path d={path} />)}
      </svg>
      <span class="text-xs text-slate-500 transition-colors duration-300 group-hover:text-slate-300">{p.name}</span>
    </div>
  ))}
</div>
