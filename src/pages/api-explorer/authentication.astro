---
import GitHubDropdown from '../../components/svelte/GitHubDropdown.svelte';
import '../../styles/global.css';
export const prerender = true;

const codeBlocks = {
  loginCurl: `curl -X POST https://api.primebrick.dev/api/v1/auth/login \\
  -H "Content-Type: application/json" \\
  -d '{"username":"your@email.com","password":"yourpassword"}'`,
  useTokenCurl: `curl -X GET https://api.primebrick.dev/api/v1/customers \\
  -H "Authorization: Bearer <your-access-token>"`,
  loginJs: `// Login
const res = await fetch('https://api.primebrick.dev/api/v1/auth/login', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({ username: 'your@email.com', password: 'yourpassword' }),
});
const { accessToken } = await res.json();

// Use the token
const data = await fetch('https://api.primebrick.dev/api/v1/customers', {
  headers: { Authorization: \`Bearer \${accessToken}\` },
});`,
  loginPython: `import requests

# Login
res = requests.post(
    'https://api.primebrick.dev/api/v1/auth/login',
    json={'username': 'your@email.com', 'password': 'yourpassword'},
)
token = res.json()['accessToken']

# Use the token
data = requests.get(
    'https://api.primebrick.dev/api/v1/customers',
    headers={'Authorization': f'Bearer {token}'},
)`,
  loginPhp: `// Login
$ch = curl_init('https://api.primebrick.dev/api/v1/auth/login');
curl_setopt_array($ch, [
    CURLOPT_POST => true,
    CURLOPT_HTTPHEADER => ['Content-Type: application/json'],
    CURLOPT_POSTFIELDS => json_encode(['username' => 'your@email.com', 'password' => 'yourpassword']),
    CURLOPT_RETURNTRANSFER => true,
]);
$token = json_decode(curl_exec($ch), true)['accessToken'];

// Use the token
$ch = curl_init('https://api.primebrick.dev/api/v1/customers');
curl_setopt_array($ch, [
    CURLOPT_HTTPHEADER => ["Authorization: Bearer $token"],
    CURLOPT_RETURNTRANSFER => true,
]);
$data = json_decode(curl_exec($ch), true);`,
  oauthCurl: `curl -X POST https://api.primebrick.dev/api/v1/auth/token \\
  -H "Content-Type: application/x-www-form-urlencoded" \\
  -d "grant_type=client_credentials" \\
  -d "client_id=your_client_id" \\
  -d "client_secret=your_client_secret"`,
  oauthUseCurl: `curl -X GET https://api.primebrick.dev/api/v1/customers \\
  -H "Authorization: Bearer <access-token>"`,
  oauthJs: `const body = new URLSearchParams({
  grant_type: 'client_credentials',
  client_id: 'your_client_id',
  client_secret: 'your_client_secret',
});

const res = await fetch('https://api.primebrick.dev/api/v1/auth/token', {
  method: 'POST',
  headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
  body,
});
const { access_token } = await res.json();

const data = await fetch('https://api.primebrick.dev/api/v1/customers', {
  headers: { Authorization: \`Bearer \${access_token}\` },
});`,
  oauthPython: `import requests

res = requests.post(
    'https://api.primebrick.dev/api/v1/auth/token',
    data={
        'grant_type': 'client_credentials',
        'client_id': 'your_client_id',
        'client_secret': 'your_client_secret',
    },
)
token = res.json()['access_token']

data = requests.get(
    'https://api.primebrick.dev/api/v1/customers',
    headers={'Authorization': f'Bearer {token}'},
)`,
  oauthPhp: `$ch = curl_init('https://api.primebrick.dev/api/v1/auth/token');
curl_setopt_array($ch, [
    CURLOPT_POST => true,
    CURLOPT_POSTFIELDS => http_build_query([
        'grant_type' => 'client_credentials',
        'client_id' => 'your_client_id',
        'client_secret' => 'your_client_secret',
    ]),
    CURLOPT_RETURNTRANSFER => true,
]);
$token = json_decode(curl_exec($ch), true)['access_token'];

$ch = curl_init('https://api.primebrick.dev/api/v1/customers');
curl_setopt_array($ch, [
    CURLOPT_HTTPHEADER => ["Authorization: Bearer $token"],
    CURLOPT_RETURNTRANSFER => true,
]);
$data = json_decode(curl_exec($ch), true);`,
  apiKeyCurl: `curl -X GET https://api.primebrick.dev/api/v1/customers \\
  -H "X-API-KEY: your_api_key_here"`,
  apiKeyJs: `const data = await fetch('https://api.primebrick.dev/api/v1/customers', {
  headers: { 'X-API-KEY': 'your_api_key_here' },
});`,
  apiKeyPython: `import requests

data = requests.get(
    'https://api.primebrick.dev/api/v1/customers',
    headers={'X-API-KEY': 'your_api_key_here'},
)`,
  apiKeyPhp: `$ch = curl_init('https://api.primebrick.dev/api/v1/customers');
curl_setopt_array($ch, [
    CURLOPT_HTTPHEADER => ['X-API-KEY: your_api_key_here'],
    CURLOPT_RETURNTRANSFER => true,
]);
$data = json_decode(curl_exec($ch), true);`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Authentication How-To — Primebrick API Explorer. Learn how to authenticate with user tokens, OAuth2 client credentials, and API keys." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Authentication — API Explorer — Primebrick</title>
  </head>
  <body class="min-h-screen antialiased">
    <nav class="api-nav">
      <div class="api-nav-inner">
        <a href="/en/" class="api-nav-logo">
          <span class="gradient-text">Primebrick</span>
        </a>
        <div class="api-nav-links">
          <a href="/getting-started/introduction/" target="_blank" rel="noopener" class="api-nav-link">Docs</a>
          <a href="/api-explorer" class="api-nav-link">API Explorer</a>
          <a href="/api-explorer/authentication" class="api-nav-link api-nav-link-active">Authentication</a>
          <GitHubDropdown client:load />
          <a
            href="https://opensource.org/license/MIT"
            target="_blank"
            rel="noopener"
            class="api-nav-link">MIT License</a
          >
        </div>
      </div>
    </nav>

    <div class="auth-container">
      <div class="auth-content">
        <h1>Authentication How-To</h1>
        <p class="auth-intro">
          Primebrick supports three authentication methods for API access. Choose the one that matches your use case.
          After configuring auth in the <a href="/api-explorer">API Explorer</a>, Scalar's built-in try-it feature will
          automatically include your credentials in requests.
        </p>

        <div class="auth-method">
          <h2>1. User Access Token</h2>
          <p>For end users logging in with username/password. The token is returned by the <code>POST /api/v1/auth/login</code> endpoint and must be sent as a Bearer token in the <code>Authorization</code> header.</p>
          <p class="auth-config"><strong>Configure in Scalar:</strong> Select "HTTP Bearer" in the auth dropdown and paste your token.</p>

          <h3>cURL</h3>
          <pre><code set:html={codeBlocks.loginCurl}></code></pre>
          <pre><code set:html={codeBlocks.useTokenCurl}></code></pre>

          <h3>JavaScript (fetch)</h3>
          <pre><code set:html={codeBlocks.loginJs}></code></pre>

          <h3>Python (requests)</h3>
          <pre><code set:html={codeBlocks.loginPython}></code></pre>

          <h3>PHP (cURL)</h3>
          <pre><code set:html={codeBlocks.loginPhp}></code></pre>
        </div>

        <div class="auth-method">
          <h2>2. OAuth2 Client Credentials</h2>
          <p>For server-to-server, machine-to-machine calls. The client credentials flow exchanges a client ID and secret for an access token via the <code>POST /api/v1/auth/token</code> endpoint.</p>
          <p class="auth-config"><strong>Configure in Scalar:</strong> Select "OAuth2" → "clientCredentials" in the auth dropdown, enter your client ID and secret.</p>

          <h3>cURL</h3>
          <pre><code set:html={codeBlocks.oauthCurl}></code></pre>
          <pre><code set:html={codeBlocks.oauthUseCurl}></code></pre>

          <h3>JavaScript (fetch)</h3>
          <pre><code set:html={codeBlocks.oauthJs}></code></pre>

          <h3>Python (requests)</h3>
          <pre><code set:html={codeBlocks.oauthPython}></code></pre>

          <h3>PHP (cURL)</h3>
          <pre><code set:html={codeBlocks.oauthPhp}></code></pre>
        </div>

        <div class="auth-method">
          <h2>3. API Key</h2>
          <p>For third-party integrations and simple scripting. The API key is sent in the <code>X-API-KEY</code> header. API keys can be generated from the admin panel or via the <code>POST /api/v1/api-keys</code> endpoint.</p>
          <p class="auth-config"><strong>Configure in Scalar:</strong> Select "API Key" in the auth dropdown, set the name to <code>X-API-KEY</code> and paste your key.</p>

          <h3>cURL</h3>
          <pre><code set:html={codeBlocks.apiKeyCurl}></code></pre>

          <h3>JavaScript (fetch)</h3>
          <pre><code set:html={codeBlocks.apiKeyJs}></code></pre>

          <h3>Python (requests)</h3>
          <pre><code set:html={codeBlocks.apiKeyPython}></code></pre>

          <h3>PHP (cURL)</h3>
          <pre><code set:html={codeBlocks.apiKeyPhp}></code></pre>
        </div>

        <div class="auth-back">
          <a href="/api-explorer">&larr; Back to API Explorer</a>
        </div>
      </div>
    </div>

    <style>
      .api-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
        padding: 0 1.5rem;
        transition: background 0.2s, border-color 0.2s;
      }

      :global([data-theme='dark']) .api-nav {
        border-bottom-color: #1e293b;
        background: #020617;
      }

      .api-nav-inner {
        max-width: 72rem;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 3.75rem;
      }

      .api-nav-logo {
        font-size: 1.25rem;
        font-weight: 700;
        text-decoration: none;
      }

      .gradient-text {
        background: linear-gradient(to right, #38bdf8, #818cf8);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }

      .api-nav-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.875rem;
      }

      .api-nav-link {
        color: #374151;
        text-decoration: none;
        transition: color 0.2s;
      }

      .api-nav-link:hover {
        color: #0ea5e9;
      }

      :global([data-theme='dark']) .api-nav-link {
        color: #d1d5db;
      }

      :global([data-theme='dark']) .api-nav-link:hover {
        color: #38bdf8;
      }

      .api-nav-link-active {
        color: #0ea5e9;
        font-weight: 600;
      }

      :global([data-theme='dark']) .api-nav-link-active {
        color: #38bdf8;
      }

      .auth-container {
        background: #f9fafb;
        min-height: calc(100vh - 3.75rem);
      }

      :global([data-theme='dark']) .auth-container {
        background: #0f172a;
      }

      .auth-content {
        max-width: 48rem;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        color: #1f2937;
      }

      :global([data-theme='dark']) .auth-content {
        color: #e2e8f0;
      }

      .auth-content h1 {
        font-size: 2.25rem;
        font-weight: 700;
        margin-bottom: 1rem;
        background: linear-gradient(to right, #0ea5e9, #6366f1);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }

      .auth-intro {
        font-size: 1.125rem;
        line-height: 1.75;
        margin-bottom: 2.5rem;
        color: #6b7280;
      }

      :global([data-theme='dark']) .auth-intro {
        color: #94a3b8;
      }

      .auth-intro a {
        color: #0ea5e9;
        text-decoration: none;
      }

      .auth-intro a:hover {
        text-decoration: underline;
      }

      .auth-method {
        margin-bottom: 3rem;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1.5rem;
        background: #ffffff;
      }

      :global([data-theme='dark']) .auth-method {
        border-color: #1e293b;
        background: #1e293b;
      }

      .auth-method h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.75rem;
        color: #0ea5e9;
      }

      :global([data-theme='dark']) .auth-method h2 {
        color: #38bdf8;
      }

      .auth-method h3 {
        font-size: 1rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        color: #374151;
      }

      :global([data-theme='dark']) .auth-method h3 {
        color: #cbd5e1;
      }

      .auth-method p {
        line-height: 1.75;
        margin-bottom: 0.75rem;
      }

      .auth-method code {
        font-family: ui-monospace, monospace;
        font-size: 0.875rem;
        background: #f3f4f6;
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        color: #0ea5e9;
      }

      :global([data-theme='dark']) .auth-method code {
        background: #0f172a;
        color: #38bdf8;
      }

      .auth-config {
        padding: 0.75rem 1rem;
        background: #f0f9ff;
        border-radius: 0.5rem;
        border-left: 3px solid #0ea5e9;
        margin: 1rem 0;
      }

      :global([data-theme='dark']) .auth-config {
        background: #0c4a6e;
      }

      .auth-method pre {
        background: #1e293b;
        border-radius: 0.5rem;
        padding: 1rem;
        overflow-x: auto;
        margin: 0.5rem 0 1rem;
      }

      .auth-method pre code {
        background: none;
        color: #e2e8f0;
        padding: 0;
        font-size: 0.8125rem;
        line-height: 1.6;
      }

      .auth-back {
        margin-top: 2rem;
        text-align: center;
      }

      .auth-back a {
        color: #0ea5e9;
        text-decoration: none;
        font-weight: 500;
      }

      .auth-back a:hover {
        text-decoration: underline;
      }
    </style>
  </body>
</html>
