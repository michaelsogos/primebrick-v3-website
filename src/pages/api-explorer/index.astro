---
import { ScalarComponent } from '@scalar/astro';

export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Primebrick API Explorer — interactive OpenAPI documentation with live try-it and multi-language code generation." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>API Explorer — Primebrick</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <nav class="border-b border-slate-800 px-6 py-4">
      <div class="mx-auto flex max-w-6xl items-center justify-between">
        <a href="/" class="text-xl font-bold text-sky-400">Primebrick</a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/features" class="text-slate-300 hover:text-sky-400 transition-colors">Features</a>
          <a href="/docs" class="text-slate-300 hover:text-sky-400 transition-colors">Docs</a>
          <a href="/api-explorer" class="text-sky-400">API Explorer</a>
          <a
            href="https://github.com/michaelsogos/primebrick-v3-website"
            class="text-slate-300 hover:text-sky-400 transition-colors"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <ScalarComponent
      renderMode="client"
      configuration={{
        spec: { url: 'http://localhost:3001/api/v1/openapi/aggregated.json' },
        hideModels: false,
        showSidebar: true,
        theme: 'default',
        layout: 'modern',
        darkMode: true,
        hideDarkModeToggle: false,
        search: true,
        operationsSorter: 'method',
        servers: [
          { url: 'http://localhost:3001', description: 'Local Development' },
          { url: 'https://api.primebrick.dev', description: 'Production' },
        ],
      }}
    />
  </body>
</html>
