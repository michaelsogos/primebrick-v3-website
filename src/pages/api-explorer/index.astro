---
import { ScalarComponent } from '@scalar/astro';
import ApiExplorerConfig from '../../components/svelte/ApiExplorerConfig.svelte';
import '../../styles/global.css';
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Primebrick API Explorer — interactive OpenAPI documentation with live try-it, API key auth, and multi-language code generation." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>API Explorer — Primebrick</title>
  </head>
  <body class="min-h-screen antialiased">
    <nav class="border-b border-slate-800 bg-slate-950 px-6 py-4 dark:border-slate-800">
      <div class="mx-auto flex max-w-6xl items-center justify-between">
        <a href="/en/" class="flex items-center gap-2 text-xl font-bold">
          <span class="bg-gradient-to-r from-sky-400 to-indigo-400 bg-clip-text text-transparent">Primebrick</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/getting-started/introduction/" class="text-slate-300 hover:text-sky-400 transition-colors dark:text-slate-300">Docs</a>
          <a href="/api-explorer" class="text-sky-400">API Explorer</a>
          <a
            href="https://github.com/michaelsogos/primebrick-v3-website"
            class="text-slate-300 hover:text-sky-400 transition-colors dark:text-slate-300"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
          <a
            href="https://github.com/michaelsogos/primebrick-v3-website/blob/main/LICENSE"
            class="text-slate-300 hover:text-sky-400 transition-colors dark:text-slate-300"
            target="_blank"
            rel="noopener"
          >
            MIT License
          </a>
        </div>
      </div>
    </nav>

    <ApiExplorerConfig client:load />

    <ScalarComponent
      renderMode="client"
      configuration={{
        spec: { url: 'http://localhost:3001/api/v1/openapi/aggregated.json' },
        hideModels: false,
        showSidebar: true,
        theme: 'default',
        layout: 'modern',
        darkMode: true,
        hideDarkModeToggle: false,
        search: true,
        operationsSorter: 'method',
        servers: [
          { url: 'http://localhost:3001', description: 'Local Development' },
          { url: 'https://api.primebrick.dev', description: 'Production' },
        ],
      }}
    />
  </body>
</html>
