---
import { ScalarComponent } from '@scalar/astro';
import ApiExplorerConfig from '../../components/svelte/ApiExplorerConfig.svelte';
import ScalarSidebarCTAs from '../../components/svelte/ScalarSidebarCTAs.svelte';
import ScalarSidebarAuth from '../../components/svelte/ScalarSidebarAuth.svelte';
import ApiVersionSelector from '../../components/svelte/ApiVersionSelector.svelte';
import GitHubDropdown from '../../components/svelte/GitHubDropdown.svelte';
import '../../styles/global.css';
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Primebrick API Explorer — interactive OpenAPI documentation with live try-it, API key auth, and multi-language code generation." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>API Explorer — Primebrick</title>
    <script is:inline>
      // Set dark theme by default on <html> and sync with Scalar's theme toggle
      (function() {
        const stored = localStorage.getItem('starlight-theme');
        const theme = stored === 'light' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', theme);

        // Observe Scalar's theme changes and sync to <html>
        const observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            if (mutation.attributeName === 'data-theme') {
              const target = mutation.target;
              if (target.getAttribute && target.getAttribute('data-theme')) {
                document.documentElement.setAttribute('data-theme', target.getAttribute('data-theme'));
              }
            }
          });
        });

        // Wait for Scalar to render, then observe its container
        function findAndObserveScalar() {
          const scalarContainer = document.querySelector('[data-theme]') || document.querySelector('.scalar-app') || document.querySelector('#scalar');
          if (scalarContainer && scalarContainer !== document.documentElement) {
            observer.observe(scalarContainer, { attributes: true, attributeFilter: ['data-theme'] });
          } else {
            setTimeout(findAndObserveScalar, 500);
          }
        }
        findAndObserveScalar();

        // Also listen for theme toggle clicks
        document.addEventListener('click', function(e) {
          const themeToggle = e.target.closest && e.target.closest('[aria-label*="theme"], .theme-toggle, .scalar-theme-toggle');
          if (themeToggle) {
            setTimeout(() => {
              const scalarTheme = document.querySelector('.scalar-app')?.getAttribute('data-theme') || 'dark';
              document.documentElement.setAttribute('data-theme', scalarTheme);
            }, 100);
          }
        });
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <!-- Sticky nav — theme-aware via data-theme attribute -->
    <nav class="api-nav">
      <div class="api-nav-inner">
        <a href="/en/" class="api-nav-logo">
          <span class="gradient-text">Primebrick</span>
        </a>
        <div class="api-nav-links">
          <a href="/getting-started/introduction/" target="_blank" rel="noopener" class="api-nav-link">Docs</a>
          <a href="/api-explorer" class="api-nav-link api-nav-link-active">API Explorer</a>
          <GitHubDropdown client:load />
          <a
            href="https://opensource.org/license/MIT"
            target="_blank"
            rel="noopener"
            class="api-nav-link">MIT License</a
          >
        </div>
      </div>
    </nav>

    <!-- Config bar (sticky) -->
    <ApiExplorerConfig client:load />

    <div class="api-version-bar">
      <ApiVersionSelector client:load />
    </div>

    <ScalarComponent
      renderMode="client"
      configuration={{
        spec: { url: 'http://localhost:3001/api/v1/openapi/aggregated.json' },
        hideModels: false,
        showSidebar: true,
        theme: 'default',
        layout: 'modern',
        darkMode: true,
        hideDarkModeToggle: false,
        search: true,
        operationsSorter: 'method',
        servers: [
          { url: 'http://localhost:3001', description: 'Local Development' },
          { url: 'https://api.primebrick.dev', description: 'Production' },
        ],
      }}
    />

    <ScalarSidebarCTAs client:load />
    <ScalarSidebarAuth client:load />

    <style>
      .api-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid #e5e7eb;
        background: #ffffff;
        padding: 0 1.5rem;
        transition: background 0.2s, border-color 0.2s;
      }

      :global([data-theme='dark']) .api-nav {
        border-bottom-color: #1e293b;
        background: #020617;
      }

      .api-nav-inner {
        max-width: 72rem;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 3.75rem;
      }

      .api-nav-logo {
        font-size: 1.25rem;
        font-weight: 700;
        text-decoration: none;
      }

      .gradient-text {
        background: linear-gradient(to right, #38bdf8, #818cf8);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }

      .api-nav-links {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.875rem;
      }

      .api-nav-link {
        color: #374151;
        text-decoration: none;
        transition: color 0.2s;
      }

      .api-nav-link:hover {
        color: #0ea5e9;
      }

      :global([data-theme='dark']) .api-nav-link {
        color: #d1d5db;
      }

      :global([data-theme='dark']) .api-nav-link:hover {
        color: #38bdf8;
      }

      .api-nav-link-active {
        color: #0ea5e9;
        font-weight: 600;
      }

      :global([data-theme='dark']) .api-nav-link-active {
        color: #38bdf8;
      }
    </style>
  </body>
</html>
