---
import { translations, LANGUAGES, type LangCode } from '../../i18n/translations';
import LanguageSwitcher from '../../components/svelte/LanguageSwitcher.svelte';
import GitHubDropdown from '../../components/svelte/GitHubDropdown.svelte';
import GitHubIcon from '../../components/GitHubIcon.astro';
import TopBanner from '../../components/astro/TopBanner.astro';
import ContactForm from '../../components/svelte/ContactForm.svelte';
import ObfuscatedEmail from '../../components/svelte/ObfuscatedEmail.svelte';
import '../../styles/global.css';

export const prerender = true;

export function getStaticPaths() {
  return LANGUAGES.map((lang) => ({
    params: { lang: lang.code === 'en' ? 'en' : lang.code },
  }));
}

const { lang } = Astro.params;
const langCode = (lang ?? 'en') as LangCode;
const t = translations[langCode] ?? translations.en;
const isEn = langCode === 'en';
const docsPath = 'https://docs.primebrick.dev';
const contactHref = isEn ? '/en/contact' : `/${langCode}/contact`;
const homeHref = isEn ? '/en/' : `/${langCode}/`;
const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? '';
---

<!doctype html>
<html lang={langCode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.contact.subtitle.slice(0, 160)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="icon" sizes="any" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon-512.png" />
    <title>PrimeBrick — {t.contact.title}</title>
    {LANGUAGES.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={`https://primebrick.dev${l.code === 'en' ? '/en/contact' : `/${l.code}/contact`}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://primebrick.dev/en/contact" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <!-- Ambient gradient background -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-sky-500/10 blur-[120px]"></div>
      <div class="absolute top-1/3 -right-40 h-[400px] w-[400px] rounded-full bg-indigo-500/10 blur-[100px]"></div>
      <div class="absolute bottom-0 -left-40 h-[400px] w-[400px] rounded-full bg-cyan-500/10 blur-[100px]"></div>
    </div>

    <!-- Top banner (sticky, non-dismissible) -->
    <TopBanner text={t.banner.text} href={contactHref} />

    <!-- Navigation (sticky, condensing on scroll) -->
    <nav id="site-nav" class="sticky top-9 z-50 border-b border-slate-800/50 bg-slate-950/40 backdrop-blur-sm transition-all duration-300">
      <div id="nav-inner" class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 transition-all duration-300">
        <a href={homeHref} class="flex items-center gap-2 transition-all duration-300" id="nav-logo" aria-label="PrimeBrick home">
          <img src="/logo-full-dark.svg" alt="PrimeBrick" width="170" height="32" class="h-7 w-auto" />
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href={docsPath} class="text-slate-300 hover:text-sky-400 transition-colors" target="_blank" rel="noopener">{t.nav.docs}</a>
          <a href={contactHref} class="text-sky-400 transition-colors">{t.nav.contact}</a>
          <a
            href="https://opensource.org/license/MIT"
            class="text-slate-300 hover:text-sky-400 transition-colors"
            target="_blank"
            rel="noopener"
          >
            {t.nav.license}
          </a>
          <GitHubDropdown client:load />
          <LanguageSwitcher client:load currentLang={langCode} />
        </div>
      </div>
    </nav>
    <script>
      (() => {
        const nav = document.getElementById('site-nav');
        const inner = document.getElementById('nav-inner');
        const logo = document.getElementById('nav-logo');
        if (!nav || !inner) return;
        const onScroll = () => {
          const scrolled = window.scrollY > 20;
          if (scrolled) {
            inner.classList.replace('py-4', 'py-2');
            nav.classList.add('bg-slate-950/80', 'backdrop-blur-md', 'shadow-lg', 'border-slate-800/80');
            nav.classList.remove('bg-slate-950/40', 'border-slate-800/50');
            logo?.classList.replace('text-xl', 'text-lg');
          } else {
            inner.classList.replace('py-2', 'py-4');
            nav.classList.remove('bg-slate-950/80', 'backdrop-blur-md', 'shadow-lg', 'border-slate-800/80');
            nav.classList.add('bg-slate-950/40', 'border-slate-800/50');
            logo?.classList.replace('text-lg', 'text-xl');
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <!-- Contact -->
    <section class="relative z-10 px-6 pt-20 pb-24">
      <div class="mx-auto max-w-2xl">
        <div class="text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-slate-700/50 bg-slate-900/50 px-4 py-1.5 text-xs font-medium text-slate-400 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-sky-400 animate-pulse"></span>
            {t.contact.badge}
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
            <span class="bg-gradient-to-b from-white to-slate-400 bg-clip-text text-transparent">{t.contact.title}</span>
          </h1>
          <p class="mx-auto mt-6 max-w-xl text-lg text-slate-400">{t.contact.subtitle}</p>
        </div>

        <div class="mt-12 rounded-3xl border border-slate-800/50 bg-slate-900/30 p-8 backdrop-blur-sm sm:p-10">
          <ContactForm client:load sitekey={turnstileSitekey} labels={t.contact.form} />

          <!-- Direct email fallback (obfuscated, anti-scraper) -->
          <div class="mt-8 border-t border-slate-800/50 pt-6 text-center text-sm text-slate-500">
            <span>{t.contact.directEmailLabel}: </span>
            <ObfuscatedEmail client:idle encoded="YWJvdXRAcHJpbWVicmljay5kZXY=" />
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-slate-800/50 px-6 py-8">
      <div class="mx-auto flex max-w-7xl items-center justify-between text-sm text-slate-500">
        <span>&copy; 2026 {t.footer.copyright}</span>
        <a
          href="https://github.com/michaelsogos/primebrick-v3-website"
          class="inline-flex items-center gap-1.5 hover:text-sky-400 transition-colors"
          target="_blank"
          rel="noopener"
        >
          <GitHubIcon class="h-4 w-4" />
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
