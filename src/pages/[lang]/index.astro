            rel="noopener"
          >
            <GitHubIcon class="h-4 w-4" />
            {t.openSource.githubLink} &rarr;
          </a>
          <span class="text-slate-600">|</span>
          <a
            href="https://opensource.org/license/MIT"
            class="text-sky-400 hover:text-sky-300 transition-colors"
            target="_blank"
            rel="noopener"
          >
            {t.openSource.licenseLink} &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="relative z-10 px-6 py-32">
      <div class="mx-auto max-w-3xl text-center">
        <div class="relative rounded-3xl border border-slate-800/50 bg-gradient-to-b from-slate-900/50 to-slate-950/50 p-12 backdrop-blur-sm">
          <div class="absolute inset-0 -z-10 rounded-3xl bg-gradient-to-r from-sky-500/5 to-indigo-500/5 blur-2xl"></div>
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.finalCta.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{t.finalCta.text}</p>
          <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
            <GitHubCTAButton client:load />
            <a
              href={docsPath}
              class="rounded-xl border border-slate-700 bg-slate-900/50 px-7 py-3.5 text-sm font-semibold text-slate-200 backdrop-blur-sm transition-all hover:border-sky-500 hover:text-sky-400 hover:scale-105"
              target="_blank"
              rel="noopener"
            >
              {t.finalCta.ctaDocs}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-slate-800/50 px-6 py-8">
      <div class="mx-auto flex max-w-7xl items-center justify-between text-sm text-slate-500">
        <span>&copy; 2026 {t.footer.copyright}</span>
        <a
          href="https://github.com/michaelsogos/primebrick-v3-website"
          class="inline-flex items-center gap-1.5 hover:text-sky-400 transition-colors"
          target="_blank"
          rel="noopener"
        >
          <GitHubIcon class="h-4 w-4" />
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
