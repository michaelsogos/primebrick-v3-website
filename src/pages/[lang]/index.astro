---
import { translations, LANGUAGES, type LangCode } from '../../i18n/translations';
import LanguageSwitcher from '../../components/svelte/LanguageSwitcher.svelte';
import GitHubDropdown from '../../components/svelte/GitHubDropdown.svelte';
import CloudLogos from '../../components/CloudLogos.astro';
import GitHubIcon from '../../components/GitHubIcon.astro';
import RotatingHeadline from '../../components/svelte/RotatingHeadline.svelte';
import GitHubCTAButton from '../../components/svelte/GitHubCTAButton.svelte';
import '../../styles/global.css';

export const prerender = true;

export function getStaticPaths() {
  return LANGUAGES.map((lang) => ({
    params: { lang: lang.code === 'en' ? 'en' : lang.code },
  }));
}

const { lang } = Astro.params;
const langCode = (lang ?? 'en') as LangCode;
const t = translations[langCode] ?? translations.en;
const isEn = langCode === 'en';
const docsPath = 'https://docs.primebrick.dev';
const apiExplorerPath = 'https://docs.primebrick.dev/api';
---

<!doctype html>
<html lang={langCode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.hero.subheadline.slice(0, 160)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Primebrick — {t.hero.headline}</title>
    {LANGUAGES.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={`https://primebrick.dev${l.code === 'en' ? '/' : `/${l.code}/`}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://primebrick.dev/" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <!-- Ambient gradient background -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-sky-500/10 blur-[120px]"></div>
      <div class="absolute top-1/3 -right-40 h-[400px] w-[400px] rounded-full bg-indigo-500/10 blur-[100px]"></div>
      <div class="absolute bottom-0 -left-40 h-[400px] w-[400px] rounded-full bg-cyan-500/10 blur-[100px]"></div>
    </div>

    <!-- Navigation -->
    <nav class="relative z-50 border-b border-slate-800/50 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href={isEn ? '/' : `/${langCode}/`} class="flex items-center gap-2 text-xl font-bold">
          <span class="bg-gradient-to-r from-sky-400 to-indigo-400 bg-clip-text text-transparent">Primebrick</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href={docsPath} class="text-slate-300 hover:text-sky-400 transition-colors" target="_blank" rel="noopener">{t.nav.docs}</a>
          <a href={apiExplorerPath} class="text-slate-300 hover:text-sky-400 transition-colors" target="_blank" rel="noopener">{t.nav.apiExplorer}</a>
          <GitHubDropdown client:load />
          <a
            href="https://opensource.org/license/MIT"
            class="text-slate-300 hover:text-sky-400 transition-colors"
            target="_blank"
            rel="noopener"
          >
            {t.nav.license}
          </a>
          <LanguageSwitcher client:load currentLang={langCode} />
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative z-10 px-6 pt-24 pb-20">
      <div class="mx-auto max-w-4xl text-center">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-slate-700/50 bg-slate-900/50 px-4 py-1.5 text-xs font-medium text-slate-400 backdrop-blur-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-sky-400 animate-pulse"></span>
          {t.hero.badge}
        </div>
        <h1 class="text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
          <span class="bg-gradient-to-b from-white to-slate-400 bg-clip-text text-transparent">
            <RotatingHeadline client:load prefix={t.hero.headlinePrefix} phrases={t.hero.rotatingPhrases} />
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 sm:text-xl">
          {t.hero.subheadline}
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <GitHubCTAButton client:load />
          <a
            href={docsPath}
            class="rounded-xl border border-slate-700 bg-slate-900/50 px-7 py-3.5 text-sm font-semibold text-slate-200 backdrop-blur-sm transition-all hover:border-sky-500 hover:text-sky-400 hover:scale-105"
            target="_blank"
            rel="noopener"
          >
            {t.hero.ctaArchitecture}
          </a>
        </div>
      </div>
    </section>

    <!-- KPI Stats -->
    <section class="relative z-10 px-6 py-8">
      <div class="mx-auto max-w-4xl grid grid-cols-3 gap-6 text-center">
        <div class="group rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-sky-500/30 hover:bg-slate-900/50">
          <div class="text-2xl font-bold bg-gradient-to-r from-sky-400 to-cyan-400 bg-clip-text text-transparent sm:text-3xl">{t.stats.license}</div>
        </div>
        <div class="group rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-indigo-500/30 hover:bg-slate-900/50">
          <div class="text-2xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent sm:text-3xl">{t.stats.deploy}</div>
        </div>
        <div class="group rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-cyan-500/30 hover:bg-slate-900/50">
          <div class="text-2xl font-bold bg-gradient-to-r from-cyan-400 to-sky-400 bg-clip-text text-transparent sm:text-3xl">{t.stats.lockin}</div>
        </div>
      </div>
    </section>

    <!-- Fake terminal/console with sticky scroll effect -->
    <section class="relative z-10 px-6 py-16">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
          <!-- Left: sticky text -->
          <div class="lg:sticky lg:top-24 lg:self-start">
            <h2 class="text-3xl font-bold text-white sm:text-4xl">
              <span class="bg-gradient-to-r from-sky-400 to-cyan-400 bg-clip-text text-transparent">From schema to production</span>
            </h2>
            <p class="mt-4 text-lg text-slate-400">
              Everything is an entity — not just your domain models, but settings, configurations, and metadata too. Define your entities, and Primebrick handles the rest: database migrations, API endpoints, RBAC, backoffice UI, tests — all generated following your conventions.
            </p>
            <div class="mt-6 space-y-3 text-sm text-slate-300">
              <div class="flex items-center gap-3">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/20 text-xs text-sky-400">1</span>
                <span>Define your entity schema</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/20 text-xs text-sky-400">2</span>
                <span>AI generates migration, CRUD API, UI, tests</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500/20 text-xs text-sky-400">3</span>
                <span>Review, approve, deploy</span>
              </div>
            </div>
          </div>

          <!-- Right: fake terminal -->
          <div class="overflow-hidden rounded-2xl border border-slate-800/50 bg-slate-950/80 shadow-2xl backdrop-blur-sm">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 border-b border-slate-800/50 px-4 py-3">
              <div class="flex gap-1.5">
                <span class="h-3 w-3 rounded-full bg-red-500/70"></span>
                <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
                <span class="h-3 w-3 rounded-full bg-green-500/70"></span>
              </div>
              <span class="ml-2 text-xs text-slate-500">primebrick@dev: ~</span>
            </div>
            <!-- Terminal body -->
            <div class="space-y-1.5 p-4 font-mono text-sm leading-relaxed">
              <div class="text-slate-500"># Describe your entity</div>
              <div class="text-green-400">$ primebrick generate entity Customer</div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> name: string (required)
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> email: string (unique)
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> status: enum [active, inactive]
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> phone: string (optional)
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> createdAt: timestamp (auto)
              </div>
              <div class="text-slate-500 mt-2"># AI generates everything...</div>
              <div class="text-cyan-400">&#10003; Database migration created</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; 00000000000003_create_customers_table.sql</div>
              <div class="text-cyan-400">&#10003; API CRUD endpoints (6 routes)</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; GET    /api/v1/customers</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; GET    /api/v1/customers/:id</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; POST   /api/v1/customers</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; PUT    /api/v1/customers/:id</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; DELETE /api/v1/customers/:id</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; POST   /api/v1/customers/bulk</div>
              <div class="text-cyan-400">&#10003; RBAC permissions configured</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; customers.read.* (guest, collaborator)</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; customers.create.* (collaborator)</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; customers.* (administrator)</div>
              <div class="text-cyan-400">&#10003; Backoffice UI pages generated</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; /admin/customers (list, detail, form)</div>
              <div class="text-cyan-400">&#10003; Test scaffolding (12 tests)</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; unit: 4 | integration: 6 | e2e: 2</div>
              <div class="text-cyan-400">&#10003; OpenAPI spec updated</div>
              <div class="text-slate-400 pl-4 text-xs">  &rarr; /api/v1/openapi/aggregated.json</div>
              <div class="text-slate-500 mt-2"># Review the generated code</div>
              <div class="text-green-400">$ primebrick review --diff</div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> 14 files changed, 847 insertions(+), 0 deletions(-)
              </div>
              <div class="text-slate-500 mt-2"># Deploy to production</div>
              <div class="text-green-400">$ primebrick deploy --env production</div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> Building TypeScript... <span class="text-green-400">&#10003;</span>
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> Running tests... <span class="text-green-400">12/12 passed &#10003;</span>
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> Migrating database... <span class="text-green-400">&#10003;</span>
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> Registering microservice... <span class="text-green-400">&#10003;</span>
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> Deploying to Cloudflare Workers... <span class="text-green-400">&#10003;</span>
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> Health check passed... <span class="text-green-400">&#10003;</span>
              </div>
              <div class="text-green-400 mt-2">&#128640; Live at https://api.primebrick.dev/v1/customers</div>
              <div class="text-slate-500 mt-2"># Verify the deployment</div>
              <div class="text-green-400">$ curl https://api.primebrick.dev/v1/customers | jq .</div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> status: 200 OK
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> count: 42 customers
              </div>
              <div class="text-slate-300">
                <span class="text-sky-400">&rarr;</span> response time: 18ms
              </div>
              <div class="flex items-center gap-1 mt-2">
                <span class="text-green-400">$</span>
                <span class="inline-block h-4 w-2 animate-pulse bg-sky-400"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Multi-cloud with logos -->
    <section class="relative z-10 px-6 py-16">
      <div class="mx-auto max-w-5xl text-center">
        <div class="sticky top-0 z-20 bg-slate-950/80 backdrop-blur-sm py-4 -mx-6 px-6">
          <h2 class="text-2xl font-bold text-white sm:text-3xl">{t.multicloud.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-slate-400">{t.multicloud.text}</p>
        </div>
        <div class="mt-10">
          <CloudLogos />
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-3 max-w-3xl mx-auto">
          {t.multicloud.labels.map((label) => (
            <div class="rounded-xl border border-slate-800/50 bg-slate-900/30 p-4 backdrop-blur-sm">
              <div class="text-sm font-semibold text-sky-400">{label.title}</div>
              <div class="mt-1 text-xs text-slate-400">{label.text}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- AI Section -->
    <section class="relative z-10 px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="text-center sticky top-0 z-20 bg-slate-950/80 backdrop-blur-sm py-4 -mx-6 px-6">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-4 py-1.5 text-xs font-medium text-indigo-300">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
            {t.ai.badge}
          </div>
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.ai.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{t.ai.text}</p>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {t.ai.cards.map((card, i) => (
            <div class="group relative rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-indigo-500/30 hover:bg-slate-900/50">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500/20 to-sky-500/20 text-indigo-400">
                {i === 0 && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>
                )}
                {i === 1 && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
                )}
                {i === 2 && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                )}
              </div>
              <h3 class="text-lg font-semibold text-white">{card.title}</h3>
              <p class="mt-2 text-sm text-slate-400">{card.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Agentic Development Section -->
    <section class="relative z-10 px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="text-center sticky top-0 z-20 bg-slate-950/80 backdrop-blur-sm py-4 -mx-6 px-6">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-4 py-1.5 text-xs font-medium text-cyan-300">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3" />
              <path d="M12 1v6m0 6v6m11-7h-6m-6 0H1m18.36-7.36l-4.24 4.24m-6.52 6.52l-4.24 4.24m12.72 0l-4.24-4.24m-6.52-6.52L4.64 4.64" />
            </svg>
            {t.agentic.badge}
          </div>
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.agentic.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{t.agentic.text}</p>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-2">
          {t.agentic.cards.map((card, i) => (
            <div class={`group relative overflow-hidden rounded-2xl border p-8 backdrop-blur-sm transition-all hover:scale-[1.02] ${i === 0 ? 'border-slate-800/50 bg-slate-900/30 hover:border-sky-500/30' : 'border-slate-800/50 bg-slate-900/30 hover:border-cyan-500/30'}`}>
              <div class={`mb-2 text-xs font-mono ${i === 0 ? 'text-sky-400' : 'text-cyan-400'}`}>
                {i === 0 ? '// TRADITIONAL' : '// AI-POWERED'}
              </div>
              <h3 class="text-2xl font-bold text-white">{card.title}</h3>
              <p class={`mt-1 text-sm font-medium ${i === 0 ? 'text-sky-400' : 'text-cyan-400'}`}>{card.subtitle}</p>
              <p class="mt-4 text-slate-400">{card.text}</p>
              {i === 0 && (
                <div class="mt-6 overflow-hidden rounded-lg border border-slate-700/50 bg-slate-950/80">
                  <!-- VSCode title bar -->
                  <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-900/80 px-3 py-1.5">
                    <div class="flex gap-1">
                      <span class="h-2.5 w-2.5 rounded-full bg-red-500/70"></span>
                      <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/70"></span>
                      <span class="h-2.5 w-2.5 rounded-full bg-green-500/70"></span>
                    </div>
                    <span class="ml-2 text-[10px] text-slate-500 font-mono">entity.schema.ts — Primebrick IDE</span>
                  </div>
                  <div class="flex h-64">
                    <!-- Left: File tree sidebar -->
                    <div class="w-28 border-r border-slate-700/50 bg-slate-900/50 p-2 text-[10px] font-mono text-slate-400 overflow-hidden">
                      <div class="text-sky-400 mb-1">EXPLORER</div>
                      <div class="text-slate-500">v PRIMEBRICK</div>
                      <div class="pl-2 text-slate-400">📁 src</div>
                      <div class="pl-4 text-sky-400">📄 schema.ts</div>
                      <div class="pl-4 text-slate-400">📄 router.ts</div>
                      <div class="pl-4 text-slate-400">📄 ui.svelte</div>
                      <div class="pl-2 text-slate-400">📁 tests</div>
                      <div class="pl-2 text-slate-400">📁 migrations</div>
                      <div class="pl-4 text-slate-500">00004_create_customers.sql</div>
                    </div>
                    <!-- Center: Code editor -->
                    <div class="flex-1 border-r border-slate-700/50 p-3 text-[10px] font-mono leading-relaxed overflow-hidden">
                      <div class="text-slate-500 mb-1">schema.ts</div>
                      <div class="text-slate-500">// Entity definition</div>
                      <div><span class="text-purple-400">export const</span> <span class="text-sky-400">Customer</span> = <span class="text-slate-300">entity</span>(&#123;&#123;</div>
                      <div class="pl-4"><span class="text-cyan-400">name</span>: <span class="text-amber-400">string</span>().required(),</div>
                      <div class="pl-4"><span class="text-cyan-400">email</span>: <span class="text-amber-400">string</span>().unique(),</div>
                      <div class="pl-4"><span class="text-cyan-400">status</span>: <span class="text-amber-400">enum</span>([<span class="text-green-400">'active'</span>]),</div>
                      <div>&#125;&#125;);</div>
                      <div class="mt-2 text-slate-500">// AI generated:</div>
                      <div class="text-cyan-400">&#10003; Migration + API + RBAC + UI + Tests</div>
                    </div>
                    <!-- Right: AI chat sidebar -->
                    <div class="w-44 bg-slate-900/50 p-2 text-[10px] font-mono overflow-hidden">
                      <div class="text-cyan-400 mb-1 flex items-center gap-1">
                        <span>&#129302;</span> AI ASSISTANT
                      </div>
                      <div class="space-y-2">
                        <div class="rounded bg-slate-800/50 p-1.5 text-slate-300">
                          <div class="text-cyan-400 text-[9px]">User:</div>
                          Generate Customer entity with CRUD
                        </div>
                        <div class="rounded bg-sky-500/10 p-1.5 text-slate-300">
                          <div class="text-sky-400 text-[9px]">AI:</div>
                          Creating entity with:
                          <div class="pl-1 text-slate-400 text-[9px] mt-0.5">
                            &#10003; Schema defined<br />
                            &#10003; Migration created<br />
                            &#10003; 6 API endpoints<br />
                            &#10003; RBAC configured<br />
                            &#10003; UI pages generated<br />
                            &#10003; 12 tests scaffolded
                          </div>
                        </div>
                        <div class="rounded border border-cyan-500/30 bg-cyan-500/5 p-1.5">
                          <div class="text-[9px] text-cyan-300">Review &amp; Approve:</div>
                          <div class="flex gap-1 mt-1">
                            <span class="rounded bg-green-500/20 px-1.5 py-0.5 text-[9px] text-green-300">&#10003; Approve</span>
                            <span class="rounded bg-red-500/20 px-1.5 py-0.5 text-[9px] text-red-300">&#10007; Reject</span>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}
              {i === 1 && (
                <div class="mt-6 overflow-hidden rounded-lg border border-slate-700/50 bg-slate-950/80">
                  <!-- Browser chrome -->
