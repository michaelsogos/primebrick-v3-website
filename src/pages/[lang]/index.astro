---
import { translations, LANGUAGES, type LangCode } from '../../i18n/translations';
import LanguageSwitcher from '../../components/svelte/LanguageSwitcher.svelte';
import GitHubDropdown from '../../components/svelte/GitHubDropdown.svelte';
import CloudLogos from '../../components/CloudLogos.astro';
import GitHubIcon from '../../components/GitHubIcon.astro';
import RotatingHeadline from '../../components/svelte/RotatingHeadline.svelte';
import SchemaToProduction from '../../components/svelte/SchemaToProduction.svelte';
import GitHubCTAButton from '../../components/svelte/GitHubCTAButton.svelte';
import TopBanner from '../../components/astro/TopBanner.astro';
import '../../styles/global.css';

export const prerender = true;

export function getStaticPaths() {
  return LANGUAGES.map((lang) => ({
    params: { lang: lang.code === 'en' ? 'en' : lang.code },
  }));
}

const { lang } = Astro.params;
const langCode = (lang ?? 'en') as LangCode;
const t = translations[langCode] ?? translations.en;
const isEn = langCode === 'en';
const docsPath = 'https://docs.primebrick.dev';
const contactHref = isEn ? '/en/contact' : `/${langCode}/contact`;
---

<!doctype html>
<html lang={langCode}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={t.hero.subheadline.slice(0, 160)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Primebrick — {t.hero.headline}</title>
    {LANGUAGES.map((l) => (
      <link rel="alternate" hreflang={l.hreflang} href={`https://primebrick.dev${l.code === 'en' ? '/' : `/${l.code}/`}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://primebrick.dev/" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <!-- Ambient gradient background -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-sky-500/10 blur-[120px]"></div>
      <div class="absolute top-1/3 -right-40 h-[400px] w-[400px] rounded-full bg-indigo-500/10 blur-[100px]"></div>
      <div class="absolute bottom-0 -left-40 h-[400px] w-[400px] rounded-full bg-cyan-500/10 blur-[100px]"></div>
    </div>

    <!-- Top banner (sticky, non-dismissible) -->
    <TopBanner text={t.banner.text} href={contactHref} />

    <!-- Navigation (sticky, condensing on scroll) -->
    <nav id="site-nav" class="sticky top-9 z-50 border-b border-slate-800/50 bg-slate-950/40 backdrop-blur-sm transition-all duration-300">
      <div id="nav-inner" class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 transition-all duration-300">
        <a href={isEn ? '/' : `/${langCode}/`} class="flex items-center gap-2 text-xl font-bold transition-all duration-300" id="nav-logo">
          <span class="bg-gradient-to-r from-sky-400 to-indigo-400 bg-clip-text text-transparent">Primebrick</span>
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href={docsPath} class="text-slate-300 hover:text-sky-400 transition-colors" target="_blank" rel="noopener">{t.nav.docs}</a>
          <a href={contactHref} class="text-sky-400 transition-colors">{t.nav.contact}</a>
          <a
            href="https://opensource.org/license/MIT"
            class="text-slate-300 hover:text-sky-400 transition-colors"
            target="_blank"
            rel="noopener"
          >
            {t.nav.license}
          </a>
          <GitHubDropdown client:load />
          <LanguageSwitcher client:load currentLang={langCode} />
        </div>
      </div>
    </nav>
    <script>
      (() => {
        const nav = document.getElementById('site-nav');
        const inner = document.getElementById('nav-inner');
        const logo = document.getElementById('nav-logo');
        if (!nav || !inner) return;
        const onScroll = () => {
          const scrolled = window.scrollY > 20;
          if (scrolled) {
            inner.classList.replace('py-4', 'py-2');
            nav.classList.add('bg-slate-950/80', 'backdrop-blur-md', 'shadow-lg', 'border-slate-800/80');
            nav.classList.remove('bg-slate-950/40', 'border-slate-800/50');
            logo?.classList.replace('text-xl', 'text-lg');
          } else {
            inner.classList.replace('py-2', 'py-4');
            nav.classList.remove('bg-slate-950/80', 'backdrop-blur-md', 'shadow-lg', 'border-slate-800/80');
            nav.classList.add('bg-slate-950/40', 'border-slate-800/50');
            logo?.classList.replace('text-lg', 'text-xl');
          }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <!-- Hero -->
    <section class="relative z-10 px-6 pt-24 pb-20">
      <div class="mx-auto max-w-4xl text-center">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-slate-700/50 bg-slate-900/50 px-4 py-1.5 text-xs font-medium text-slate-400 backdrop-blur-sm">
          <span class="h-1.5 w-1.5 rounded-full bg-sky-400 animate-pulse"></span>
          {t.hero.badge}
        </div>
        <h1 class="text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
          <span class="bg-gradient-to-b from-white to-slate-400 bg-clip-text text-transparent">
            <RotatingHeadline client:load prefix={t.hero.headlinePrefix} phrases={t.hero.rotatingPhrases} />
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400 sm:text-xl">
          {t.hero.subheadline}
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <GitHubCTAButton client:load />
          <a
            href={docsPath}
            class="rounded-xl border border-slate-700 bg-slate-900/50 px-7 py-3.5 text-sm font-semibold text-slate-200 backdrop-blur-sm transition-all hover:border-sky-500 hover:text-sky-400 hover:scale-105"
            target="_blank"
            rel="noopener"
          >
            {t.hero.ctaArchitecture}
          </a>
        </div>
      </div>
    </section>

    <!-- KPI Stats -->
    <section class="relative z-10 px-6 py-8">
      <div class="mx-auto max-w-4xl grid grid-cols-3 gap-6 text-center">
        <div class="group rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-sky-500/30 hover:bg-slate-900/50">
          <svg class="mx-auto mb-3 h-8 w-8 text-sky-400 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v18M3 12h18" /><circle cx="12" cy="12" r="9" /><path d="M7 8c2 2 8 2 10 0M7 16c2-2 8-2 10 0" /></svg>
          <div class="text-2xl font-bold bg-gradient-to-r from-sky-400 to-cyan-400 bg-clip-text text-transparent sm:text-3xl">{t.stats.license}</div>
        </div>
        <div class="group rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-indigo-500/30 hover:bg-slate-900/50">
          <svg class="mx-auto mb-3 h-8 w-8 text-indigo-400 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" /><path d="M12 12v4M10 14h4" /></svg>
          <div class="text-2xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent sm:text-3xl">{t.stats.deploy}</div>
        </div>
        <div class="group rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-cyan-500/30 hover:bg-slate-900/50">
          <svg class="mx-auto mb-3 h-8 w-8 text-cyan-400 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
          <div class="text-2xl font-bold bg-gradient-to-r from-cyan-400 to-sky-400 bg-clip-text text-transparent sm:text-3xl">{t.stats.lockin}</div>
        </div>
      </div>
    </section>

    <!-- Scroll-triggered terminal: schema to production -->
    <SchemaToProduction client:load />

    <!-- Multi-cloud with logos -->
    <section class="relative z-10 px-6 py-16">
      <div class="mx-auto max-w-5xl text-center">
        <div class="sticky top-9 z-20 bg-slate-950/80 backdrop-blur-sm py-4 -mx-6 px-6">
          <h2 class="text-2xl font-bold text-white sm:text-3xl">{t.multicloud.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-slate-400">{t.multicloud.text}</p>
        </div>
        <div class="mt-10">
          <CloudLogos />
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-3 max-w-3xl mx-auto">
          {t.multicloud.labels.map((label) => (
            <div class="rounded-xl border border-slate-800/50 bg-slate-900/30 p-4 backdrop-blur-sm">
              <div class="text-sm font-semibold text-sky-400">{label.title}</div>
              <div class="mt-1 text-xs text-slate-400">{label.text}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- AI Section -->
    <section class="relative z-10 px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="text-center sticky top-9 z-20 bg-slate-950/80 backdrop-blur-sm py-4 -mx-6 px-6">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-4 py-1.5 text-xs font-medium text-indigo-300">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
            {t.ai.badge}
          </div>
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.ai.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{t.ai.text}</p>
        </div>
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {t.ai.cards.map((card, i) => (
            <div class="group relative rounded-2xl border border-slate-800/50 bg-slate-900/30 p-6 backdrop-blur-sm transition-all hover:border-indigo-500/30 hover:bg-slate-900/50">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500/20 to-sky-500/20 text-indigo-400">
                {i === 0 && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" /></svg>
                )}
                {i === 1 && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
                )}
                {i === 2 && (
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                )}
              </div>
              <h3 class="text-lg font-semibold text-white">{card.title}</h3>
              <p class="mt-2 text-sm text-slate-400">{card.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Agentic Development Section -->
    <section class="relative z-10 px-6 py-24">
      <div class="mx-auto max-w-5xl">
        <div class="text-center sticky top-9 z-20 bg-slate-950/80 backdrop-blur-sm py-4 -mx-6 px-6">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-4 py-1.5 text-xs font-medium text-cyan-300">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3" />
              <path d="M12 1v6m0 6v6m11-7h-6m-6 0H1m18.36-7.36l-4.24 4.24m-6.52 6.52l-4.24 4.24m12.72 0l-4.24-4.24m-6.52-6.52L4.64 4.64" />
            </svg>
            {t.agentic.badge}
          </div>
          <h2 class="text-3xl font-bold text-white sm:text-4xl">{t.agentic.title}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{t.agentic.text}</p>
        </div>

        <!-- Stacked wireframes: Agentic FIRST, then IDE -->
        <div class="mt-12 grid gap-8 max-w-4xl mx-auto">

          <!-- Card 1: Agentic GUI (was i === 1, now first) -->
          <div class="group relative overflow-hidden rounded-2xl border border-slate-800/50 bg-slate-900/30 p-8 backdrop-blur-sm transition-all hover:border-cyan-500/30">
            <div class="mb-2 text-xs font-mono text-cyan-400">// AI-POWERED</div>
            <h3 class="text-2xl font-bold text-white">{t.agentic.cards[1].title}</h3>
            <p class="mt-1 text-sm font-medium text-cyan-400">{t.agentic.cards[1].subtitle}</p>
            <p class="mt-4 text-slate-400">{t.agentic.cards[1].text}</p>

            <!-- Agentic wireframe: realistic agent GUI -->
            <div class="mt-6 overflow-hidden rounded-lg border border-slate-700/50 bg-slate-950/80">
              <!-- Title bar -->
              <div class="flex items-center gap-2 border-b border-slate-700/50 bg-slate-900/80 px-3 py-1.5">
                <div class="flex gap-1">
                  <span class="h-2.5 w-2.5 rounded-full bg-red-500/70"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/70"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-green-500/70"></span>
                </div>
                <div class="ml-2 flex-1 rounded bg-slate-800/50 px-2 py-0.5 text-[10px] text-slate-500 font-mono">
                  &#128274; primebrick.dev/agent/cowork
                </div>
              </div>
              <div class="flex h-[480px] text-xs">
                <!-- Left: Sessions sidebar -->
                <div class="hidden sm:block w-48 border-r border-slate-700/50 bg-slate-900/50 p-2 font-mono overflow-hidden">
                  <div class="text-cyan-400 mb-2 text-[10px] font-semibold tracking-wide">SESSIONS</div>
                  <div class="space-y-1">
                    <div class="rounded bg-sky-500/10 p-2 text-sky-300">
                      <div class="font-semibold text-[11px]">Customer Entity</div>
                      <div class="text-[9px] text-slate-500 mt-0.5">2 min ago</div>
                    </div>
                    <div class="rounded p-2 text-slate-400 hover:bg-slate-800/50">
                      <div class="text-[11px]">Order Entity</div>
                      <div class="text-[9px] text-slate-500 mt-0.5">1 hour ago</div>
                    </div>
                    <div class="rounded p-2 text-slate-400 hover:bg-slate-800/50">
                      <div class="text-[11px]">Auth Module</div>
                      <div class="text-[9px] text-slate-500 mt-0.5">Yesterday</div>
                    </div>
                    <div class="rounded p-2 text-slate-400 hover:bg-slate-800/50">
                      <div class="text-[11px]">RBAC Refactor</div>
                      <div class="text-[9px] text-slate-500 mt-0.5">3 days ago</div>
                    </div>
                    <div class="mt-3 rounded border border-dashed border-slate-700 p-2 text-center text-[10px] text-slate-500">
                      + New Session
                    </div>
                  </div>
                </div>

                <!-- Center: Chat area (DOMINANT) -->
                <div class="flex-1 flex flex-col overflow-hidden">
                  <div class="border-b border-slate-700/50 px-3 py-1.5 text-[10px] text-slate-500 font-mono">
                    Customer Entity — Session #42
                  </div>
                  <div class="flex-1 space-y-3 p-3 overflow-hidden">
                    <div class="flex justify-end">
                      <div class="max-w-[80%] rounded-lg rounded-br-sm bg-sky-500/20 px-3 py-2 text-slate-200 text-[11px]">
                        Create a Customer entity with name, email, and status fields
                      </div>
                    </div>
                    <div class="flex justify-start">
                      <div class="max-w-[80%] rounded-lg rounded-bl-sm bg-slate-800/50 px-3 py-2 text-slate-300 text-[11px]">
                        <div class="text-cyan-400 font-semibold mb-1 text-[10px]">&#129302; AI Agent</div>
                        I'll create the Customer entity. Here's my plan:
                        <div class="mt-1.5 pl-2 text-slate-400 text-[10px] space-y-0.5">
                          <div>1. Schema: name, email, status</div>
                          <div>2. Migration: 00004_create_customers</div>
                          <div>3. API: 6 CRUD endpoints</div>
                          <div>4. RBAC: customers.* permissions</div>
                          <div>5. UI: list, detail, form pages</div>
                          <div>6. Tests: 12 scaffolds</div>
                        </div>
                      </div>
                    </div>
                    <!-- Plan approval CTA -->
                    <div class="rounded-lg border border-cyan-500/30 bg-cyan-500/5 p-2.5">
                      <div class="text-[11px] text-cyan-300 font-semibold mb-1.5">Plan ready — 14 files to create/modify:</div>
                      <div class="flex gap-1.5">
                        <button class="rounded bg-green-500/20 px-2.5 py-1 text-[10px] text-green-300 font-semibold">&#10003; Approve &amp; Execute</button>
                        <button class="rounded bg-red-500/20 px-2.5 py-1 text-[10px] text-red-300 font-semibold">&#10007; Reject</button>
                        <button class="rounded bg-slate-700/50 px-2.5 py-1 text-[10px] text-slate-300 font-semibold">&#128065; Preview Diff</button>
                      </div>
                    </div>
                  </div>
                  <!-- Input bar -->
                  <div class="border-t border-slate-700/50 p-2.5">
                    <div class="flex items-center gap-2 rounded-lg bg-slate-800/50 px-3 py-2">
                      <span class="text-slate-500 text-[11px]">Ask the agent to build something...</span>
                      <span class="ml-auto rounded bg-sky-500/20 px-2 py-0.5 text-[10px] text-sky-300 font-semibold">Send</span>
                    </div>
                  </div>
                </div>

                <!-- Right: Changed files sidebar -->
                <div class="hidden sm:block w-44 border-l border-slate-700/50 bg-slate-900/50 p-2 font-mono overflow-hidden">
                  <div class="text-cyan-400 mb-2 text-[10px] font-semibold tracking-wide">CHANGED FILES (14)</div>
                  <div class="space-y-0.5 text-[10px]">
                    <div class="text-green-400">+ src/entities/customer.ts</div>
                    <div class="text-green-400">+ src/modules/customer/router.ts</div>
                    <div class="text-green-400">+ src/modules/customer/ui.svelte</div>
                    <div class="text-green-400">+ db-meta/patches/00004.sql</div>
                    <div class="text-green-400">+ tests/customer.test.ts</div>
                    <div class="text-green-400">+ tests/customer-e2e.test.ts</div>
                    <div class="text-amber-400">~ src/openapi/openapi.ts</div>
                    <div class="text-amber-400">~ src/index.ts</div>
                    <div class="text-amber-400">~ src/modules/auth/permissions.ts</div>
                    <div class="text-slate-500">... 5 more</div>
                  </div>
                  <div class="mt-3 border-t border-slate-700/50 pt-2">
                    <div class="text-[9px] text-slate-500">+847 -0 lines</div>
                    <div class="text-[9px] text-green-400 mt-0.5">All tests passing (12/12)</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute -bottom-10 -right-10 h-32 w-32 rounded-full blur-3xl bg-cyan-500/5 transition-all group-hover:opacity-100"></div>
          </div>

          <!-- Card 2: IDE wireframe (was i === 0, now second) -->
          <div class="group relative overflow-hidden rounded-2xl border border-slate-800/50 bg-slate-900/30 p-8 backdrop-blur-sm transition-all hover:border-sky-500/30">
            <div class="mb-2 text-xs font-mono text-sky-400">// TRADITIONAL</div>
            <h3 class="text-2xl font-bold text-white">{t.agentic.cards[0].title}</h3>
            <p class="mt-1 text-sm font-medium text-sky-400">{t.agentic.cards[0].subtitle}</p>
            <p class="mt-4 text-slate-400">{t.agentic.cards[0].text}</p>

            <!-- IDE wireframe: realistic VSCode skeleton -->
            <div class="mt-6 overflow-hidden rounded-lg border border-slate-700/50 bg-[#1e1e2e]">
              <!-- VSCode title bar -->
              <div class="flex items-center gap-2 border-b border-slate-700/50 bg-[#333333] px-3 py-1.5">
                <div class="flex gap-1">
                  <span class="h-2.5 w-2.5 rounded-full bg-red-500/70"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-yellow-500/70"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-green-500/70"></span>
                </div>
                <span class="ml-2 text-[10px] text-slate-400 font-mono">entity.schema.ts — Primebrick IDE — Visual Studio Code</span>
              </div>
              <div class="flex h-[480px] text-xs">
                <!-- Left: Activity bar + Explorer -->
                <div class="hidden sm:flex">
                  <!-- Activity bar -->
                  <div class="w-12 bg-[#333333] border-r border-slate-700/50 flex flex-col items-center py-3 gap-4">
                    <div class="h-5 w-5 rounded bg-sky-600/80"></div>
                    <div class="h-5 w-5 rounded bg-slate-600/50"></div>
                    <div class="h-5 w-5 rounded bg-slate-600/50"></div>
                    <div class="h-5 w-5 rounded bg-slate-600/50"></div>
                  </div>
                  <!-- Explorer -->
                  <div class="w-40 border-r border-slate-700/50 bg-[#252526] p-2 font-mono overflow-hidden">
                    <div class="text-sky-400 mb-2 text-[10px] font-semibold tracking-wide">EXPLORER</div>
                    <div class="text-slate-500 text-[10px] mb-1">v PRIMEBRICK</div>
                    <div class="pl-1 text-slate-400 text-[10px]">v src</div>
                    <div class="pl-4 text-sky-400 text-[10px]">entity.schema.ts</div>
                    <div class="pl-4 text-slate-400 text-[10px]">router.ts</div>
                    <div class="pl-4 text-slate-400 text-[10px]">ui.svelte</div>
                    <div class="pl-1 text-slate-400 text-[10px]">v tests</div>
                    <div class="pl-1 text-slate-400 text-[10px]">v migrations</div>
                    <div class="pl-4 text-slate-500 text-[10px]">00004_create_customers.sql</div>
                  </div>
                </div>

                <!-- Center: Code editor (DOMINANT) -->
                <div class="flex-1 flex flex-col overflow-hidden bg-[#1e1e2e]">
                  <!-- Tab bar -->
                  <div class="flex border-b border-slate-700/50 bg-[#252526]">
