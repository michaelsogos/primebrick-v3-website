---
import '../../styles/global.css';
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Primebrick features — microservices, RBAC, type-safe DAL, SvelteKit frontend, OpenAPI." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Features — Primebrick</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <nav class="border-b border-slate-800 px-6 py-4">
      <div class="mx-auto flex max-w-6xl items-center justify-between">
        <a href="/" class="text-xl font-bold text-sky-400">Primebrick</a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/features" class="text-sky-400">Features</a>
          <a href="/docs" class="text-slate-300 hover:text-sky-400 transition-colors">Docs</a>
          <a href="/api-explorer" class="text-slate-300 hover:text-sky-400 transition-colors">API Explorer</a>
          <a
            href="https://github.com/michaelsogos/primebrick-v3-website"
            class="text-slate-300 hover:text-sky-400 transition-colors"
            target="_blank"
            rel="noopener"
          >
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <section class="px-6 py-16">
      <div class="mx-auto max-w-4xl">
        <h1 class="text-4xl font-bold text-white">Features</h1>
        <p class="mt-4 text-lg text-slate-400">
          A comprehensive overview of what Primebrick offers.
        </p>

        <div class="mt-12 space-y-12">
          <div>
            <h2 class="text-2xl font-semibold text-sky-400">Microservices Architecture</h2>
            <ul class="mt-4 space-y-2 text-slate-400">
              <li>Service registry with heartbeats and stale-instance detection</li>
              <li>Round-robin proxy at /ws/:serviceCode for transparent service routing</li>
              <li>NATS messaging for inter-service communication</li>
              <li>Each microservice self-registers via @primebrick/sdk</li>
              <li>RFC 7807 Problem Details for all error responses</li>
            </ul>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-sky-400">RBAC with Casdoor IDP</h2>
            <ul class="mt-4 space-y-2 text-slate-400">
              <li>Wildcard-based permissions (e.g. customers.read.*, customers.*)</li>
              <li>Role mappings stored in database, integrated with Casdoor</li>
              <li>Admin bypass for is_admin=true users</li>
              <li>OAuth2 / OIDC support via Casdoor</li>
              <li>JWT access tokens + refresh token cookies</li>
            </ul>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-sky-400">Type-Safe Data Access Layer</h2>
            <ul class="mt-4 space-y-2 text-slate-400">
              <li>Metadata-driven Repository pattern with TypeScript decorators</li>
              <li>@Entity, @Column, @Key, @Unique, @AuditableField, @DeletableField</li>
              <li>Soft-delete and audit fields built-in</li>
              <li>Bulk operations via temp tables (atomic, SQL-injection safe)</li>
              <li>Native bigint support (INT8_OID), not strings</li>
            </ul>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-sky-400">SvelteKit Frontend</h2>
            <ul class="mt-4 space-y-2 text-slate-400">
              <li>Tailwind CSS 4 + shadcn-svelte components</li>
              <li>Server-side sort, filter, and pagination</li>
              <li>Snake_case end-to-end (DB → BE → FE, no DTO transformation)</li>
              <li>Form validation with sveltekit-superforms + Zod</li>
            </ul>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-sky-400">OpenAPI First</h2>
            <ul class="mt-4 space-y-2 text-slate-400">
              <li>Every service exposes its OpenAPI spec at /api/openapi.json</li>
              <li>Backend aggregates all microservice specs into one endpoint</li>
              <li>Interactive API explorer with Scalar (try-it, code gen, auth)</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <footer class="border-t border-slate-800 px-6 py-8">
      <div class="mx-auto flex max-w-6xl items-center justify-between text-sm text-slate-500">
        <span>&copy; 2026 Primebrick. MIT License.</span>
        <a
          href="https://github.com/michaelsogos/primebrick-v3-website"
          class="hover:text-sky-400 transition-colors"
          target="_blank"
          rel="noopener"
        >
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
